# ClawOS Telegram Adapter — environment variables
# Deployed on Lightsail alongside the skill worker.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003

# ── Telegram (Chat 5) ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Arbitrary secret sent with every webhook update — used for HMAC validation.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ── Agent API (Chat 5) ────────────────────────────────────────────────────────
AGENT_API_URL=https://your-api.vercel.app

# ── Supabase (Chat 2) ─────────────────────────────────────────────────────────
# Service role key — bypasses RLS. Never expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key