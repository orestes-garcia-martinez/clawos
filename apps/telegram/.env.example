# ClawOS Telegram Adapter -- environment variables
# Copy to .env and fill in values. Never commit .env.

# -- Server ────────────────────────────────────────────────────────────────────
PORT=3003

# -- Telegram Bot API ──────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather
# Arbitrary secret registered via setWebhook -- sent with every update.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# -- Agent API (Vercel) ────────────────────────────────────────────────────────
AGENT_API_URL=https://your-api.vercel.app

# -- Service-to-service auth -- must match SERVICE_SECRET in apps/api/.env ─────
# Generate: openssl rand -hex 32
SERVICE_SECRET=generate-with-openssl-rand-hex-32

# -- /link token HMAC secret -- must match LINK_TOKEN_SECRET in apps/web/.env ──
# Generate: openssl rand -hex 32
LINK_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# -- Supabase -- service role key bypasses RLS for identity management ─────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
