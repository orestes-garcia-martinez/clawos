{
  "name": "@clawos/telegram",
  "version": "0.2.1",
  "private": true,
  "description": "ClawOS Telegram bot adapter -- webhook handler for Bot API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --exclude 'src/**/*.integration.test.ts'",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@clawos/security": "*",
    "@clawos/shared": "*",
    "express": "^5.0.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.0",
    "supertest": "^7.0.0",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "^4.1.5"
  }
}
