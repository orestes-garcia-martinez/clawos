# apps/telegram/.env.test
# Integration test credentials. Never commit this file.
# Copy from .env and fill in real values before running: npm run test:integration
#
# Requirements:
#   - Supabase project running with all Chat 2/3 migrations applied (including link_tokens)
#   - Telegram bot registered and TELEGRAM_WEBHOOK_SECRET set
#   - Agent API deployed to Vercel (AGENT_API_URL)
#   - Lightsail skill worker running -- integration tests send real job-search
#     messages that invoke careerclaw-js via the worker. If the worker is down,
#     the text message and session continuity tests will fail.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3003

# ── Supabase (service role -- bypasses RLS for test setup/teardown) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Telegram Bot ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=telegram-bot-token-here
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=sdk-clawos-telegram-webhook-...

# Your own Telegram chat ID with the bot.
# To find it: message your bot, check the Lightsail logs for the update payload,
# look for message.chat.id. In a private chat, this equals your Telegram user ID.
# The integration tests will send REAL messages to this chat ID.
TELEGRAM_TEST_CHAT_ID=chat-id-here

# ── Agent API (deployed Vercel endpoint) ──────────────────────────────────────
AGENT_API_URL=https://vercel-agent-api-url-here

# Must match SERVICE_SECRET in apps/api/.env
# Generate with: openssl rand -hex 32
SERVICE_SECRET=sk-clawos-service-...

# Must match LINK_TOKEN_SECRET in apps/web/.env (Chat 6)
# Generate with: openssl rand -hex 32
LINK_TOKEN_SECRET=sk-clawos-link-...

# ── Optional: PDF extraction test ─────────────────────────────────────────────
# file_id of a real PDF you have already sent to the bot.
# To get it: send a PDF to your bot, check the Lightsail telegram logs for
# message.document.file_id. The file must still be available (Telegram keeps
# files for at least 1 hour after upload for bots).
# Leave empty to skip the PDF integration test.
TELEGRAM_TEST_PDF_FILE_ID=
