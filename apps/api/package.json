{
  "name": "@clawos/api",
  "version": "0.10.0",
  "private": true,
  "description": "ClawOS Agent API — Hono + Claude orchestration",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.80.0",
    "@clawos/billing": "*",
    "@clawos/security": "*",
    "@clawos/shared": "*",
    "@hono/node-server": "^1.13.0",
    "hono": "^4.12.8",
    "openai": "^4.96.0",
    "pdf-parse": "^1.1.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "^3.2.4"
  }
}
