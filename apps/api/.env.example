# ClawOS Agent API — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
# Service role key — server-side only, never exposed to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM — platform keys, isolated from skill-level keys ──────────────────────
# Primary: Claude (Anthropic) — required
CLAWOS_ANTHROPIC_KEY=sk-ant-...
# Failover: OpenAI gpt-4o-mini — optional, but strongly recommended
CLAWOS_OPENAI_KEY=sk-...

# ── Lightsail skill worker ────────────────────────────────────────────────────
WORKER_URL=http://100.103.12.74:3002
# Generate with: openssl rand -hex 32  (must match WORKER_SECRET in apps/worker/.env)
WORKER_SECRET=

# -- CORS ──────────────────────────────────────────────────────────────────────
# Production: your actual domain e.g. https://clawos.com
ALLOWED_ORIGIN=http://localhost:5173

# -- Service-to-service auth -- internal channel adapters (Telegram, WhatsApp) -
# Generate with: openssl rand -hex 32
# Must match SERVICE_SECRET in each channel adapter's .env (apps/telegram/.env etc.)
SERVICE_SECRET=

# -- /link token HMAC secret -- must match LINK_TOKEN_SECRET in apps/telegram/.env ──
# Generate: openssl rand -hex 32
LINK_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# ── Billing — Polar.sh (Chat 7) ───────────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=

