# ClawOS Agent API — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM — platform keys, isolated from skill-level keys ──────────────────────
CLAWOS_ANTHROPIC_KEY=sk-ant-...
CLAWOS_OPENAI_KEY=sk-...

# ── Lightsail skill worker ────────────────────────────────────────────────────
WORKER_URL=http://100.103.12.74:3002
WORKER_SECRET=

# ── Signed skill assertions (API -> worker) ──────────────────────────────────
# Ed25519 private key in PEM format. Escape newlines as \n if storing in a
# single-line secret manager value.
SKILL_ASSERTION_PRIVATE_KEY=
# Logical key id used for rotation, e.g. skill-assertion-2026-03
SKILL_ASSERTION_KEY_ID=skill-assertion-current

# -- CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:5173

# -- Service-to-service auth -- internal channel adapters (Telegram, WhatsApp) -
SERVICE_SECRET=

# -- /link token HMAC secret -- must match LINK_TOKEN_SECRET in apps/telegram/.env ──
LINK_TOKEN_SECRET=generate-with-openssl-rand-hex-32

# ── Billing — Polar.sh ───────────────────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=
POLAR_ENV=sandbox
POLAR_PRODUCT_CAREERCLAW_PRO_ID=
POLAR_BENEFIT_CAREERCLAW_PRO_ACCESS_ID=

# ── Internal admin API key ────────────────────────────────────────────────────
INTERNAL_API_KEY=

# ── Web app base URL — used to build billing return/success URLs ──────────────
WEB_APP_URL=https://app.clawoshq.com
