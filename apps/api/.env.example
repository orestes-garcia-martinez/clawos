# ClawOS Agent API — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001

# ── Supabase (Chat 2) ─────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── LLM — platform keys isolated from skill keys (Chat 4) ────────────────────
# Primary: Claude (Anthropic)
CLAWOS_ANTHROPIC_KEY=sk-ant-...
# Failover: OpenAI
CLAWOS_OPENAI_KEY=sk-...

# ── Lightsail skill worker (Chat 3) ──────────────────────────────────────────
WORKER_URL=http://100.103.12.74:3002
WORKER_SECRET=generate-with-openssl-rand-hex-32

# ── Billing — Polar.sh (Chat 7) ───────────────────────────────────────────────
POLAR_ACCESS_TOKEN=polar_at_...
POLAR_WEBHOOK_SECRET=generate-with-openssl-rand-hex-32

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGIN=https://clawos.com
