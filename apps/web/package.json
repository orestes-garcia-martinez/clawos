{
  "name": "@clawos/web",
  "version": "0.4.0",
  "private": true,
  "description": "ClawOS web frontend — React + Vite + Tailwind 4",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "tsx src/scripts/fetch-skill-versions.ts",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@clawos/shared": "*",
    "@supabase/supabase-js": "^2.49.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "jsdom": "^29.0.1",
    "msw": "^2.12.14",
    "tailwindcss": "^4.0.0",
    "typescript": "*",
    "vite": "^8.0.3",
    "vitest": "^3.0.0"
  }
}
