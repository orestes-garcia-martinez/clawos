# ClawOS Web Frontend — environment variables
# Copy to .env and fill in values. Never commit .env.
# Vite exposes only VITE_* prefixed vars to the browser.

# ── Agent API ─────────────────────────────────────────────────────────────────
# Dev (Vite proxy rewrites /api/* → this URL, so raw IP is fine):
VITE_API_URL=http://100.103.12.74:3001
# Production: set to your HTTPS subdomain once Nginx + SSL are configured:
# VITE_API_URL=https://api.yourdomain.com

# ── Supabase ──────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Mock mode (local dev without real backends) ───────────────────────────
# Set to "true" to use in-memory mocks for Supabase and the Agent API.
VITE_MOCK=false