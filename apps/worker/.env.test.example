# ScrapeClaw E2E integration smoke test — environment variables
# Copy this file to .env.test and fill in real values.
# .env.test is gitignored. Never commit real credentials.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── ScrapeClaw discovery ──────────────────────────────────────────────────────
SCRAPECLAW_GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── ScrapeClaw research + enrichment ─────────────────────────────────────────
SCRAPECLAW_ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Test user ─────────────────────────────────────────────────────────────────
# UUID of an existing user in auth.users (dev Supabase project).
# All rows written by the smoke test will be owned by this user and deleted
# in afterAll — the user account itself is never touched.
TEST_USER_ID=00000000-0000-0000-0000-000000000000
