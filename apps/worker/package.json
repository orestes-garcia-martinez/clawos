{
  "name": "@clawos/worker",
  "version": "0.8.0",
  "private": true,
  "description": "ClawOS Lightsail skill worker — Express wrapper for direct CareerClaw runtime execution",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@clawos/security": "*",
    "@clawos/shared": "*",
    "careerclaw-js": "^1.11.1",
    "express": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/supertest": "^2.0.16",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.4",
    "tsx": "^4.19.0",
    "typescript": "*",
    "vitest": "^3.2.4"
  }
}
