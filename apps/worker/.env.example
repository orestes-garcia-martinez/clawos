# ClawOS Skill Worker — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to the repo.

# ── Required ──────────────────────────────────────────────────────────────────

# Shared secret used by the Agent API to authenticate requests to this worker.
WORKER_SECRET=

# JSON object mapping assertion key id -> Ed25519 public key PEM.
# Store escaped newlines as \n in single-line secrets.
# Example:
# SKILL_ASSERTION_PUBLIC_KEYS_JSON={"skill-assertion-current":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}
SKILL_ASSERTION_PUBLIC_KEYS_JSON={}

# ── Worker config ─────────────────────────────────────────────────────────────

PORT=3002
SKILL_EXECUTION_TIMEOUT_MS=60000
CAREERCLAW_BIN_PATH=
CAREERCLAW_WORKSPACE_DIR=/home/clawos-admin/careerclaw-workspace

# ── CareerClaw LLM keys (Pro features after direct-import integration) ──────
CAREERCLAW_ANTHROPIC_KEY=
CAREERCLAW_OPENAI_KEY=
CAREERCLAW_LLM_CHAIN=

# ── Semantic matching (Phase 1) config ─────────────────────────────────────────
CAREERCLAW_SEMANTIC_MATCHING=true
