# ClawOS Skill Worker — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to the repo.

# ── Required ──────────────────────────────────────────────────────────────────

# Shared secret used by the Agent API to authenticate requests to this worker.
# Generate with: openssl rand -hex 32
# Must match WORKER_SECRET in apps/api/.env
WORKER_SECRET=

# ── Worker config ─────────────────────────────────────────────────────────────

# Port the worker listens on (default: 3002)
PORT=3002

# Workspace directory for temporary skill run files.
# Must be writable by the service user (clawos-admin).
# Temp files are created here and deleted immediately after each run.
CAREERCLAW_WORKSPACE_DIR=/home/clawos-admin/careerclaw-workspace

# ── CareerClaw LLM keys (Pro features) ───────────────────────────────────────
# These keys are isolated from the platform Claude API key (used by the Agent API).
# See security architecture: Section 4.4 — Environment variable isolation.

# Anthropic API key for LLM-enhanced outreach drafts (CareerClaw Pro)
CAREERCLAW_ANTHROPIC_KEY=

# OpenAI API key for LLM failover chain (CareerClaw Pro)
CAREERCLAW_OPENAI_KEY=

# LLM failover chain — e.g. anthropic/claude-haiku-4-5-20251001,openai/gpt-4o-mini
# Leave blank to use the default chain from careerclaw-js
CAREERCLAW_LLM_CHAIN=

# ── Supabase (used only for run logging by the Agent API, not the worker) ────
# The worker itself is stateless — it does not write to Supabase.
# These vars are documented here for reference; set them in apps/api/.env.
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
