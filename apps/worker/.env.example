# ClawOS Lightsail Skill Worker — environment variables
# Deployed on Lightsail as an always-on Express server.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002

# ── Worker authentication (Chat 3) ────────────────────────────────────────────
# Shared secret — Agent API must send this in X-Worker-Secret header.
# Generate: openssl rand -hex 32
WORKER_SECRET=generate-with-openssl-rand-hex-32

# ── Supabase (Chat 2) ─────────────────────────────────────────────────────────
# Service role key — bypasses RLS. Never expose to the browser.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── CareerClaw LLM keys (Chat 3) — isolated from platform keys ───────────────
CAREERCLAW_ANTHROPIC_KEY=sk-ant-...
CAREERCLAW_OPENAI_KEY=sk-...
