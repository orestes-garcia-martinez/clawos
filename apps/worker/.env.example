# ClawOS Skill Worker — environment variables
# Deployed on Lightsail. Copy to .env and fill in values.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3002

# ── Auth — shared secret with Agent API ──────────────────────────────────────
# Generate: openssl rand -hex 32
WORKER_SECRET=generate-with-openssl-rand-hex-32

# ── Workspace dir — CLI writes here only (Chat 3) ────────────────────────────
WORKSPACE_DIR=/home/clawos-worker/workspace

# ── LLM keys — skill-level, isolated from platform API keys ──────────────────
# These are the careerclaw-js LLM keys, NOT the platform Claude API key.
CAREERCLAW_ANTHROPIC_KEY=sk-ant-...
CAREERCLAW_OPENAI_KEY=sk-...

# ── Audit log path (Chat 3) ───────────────────────────────────────────────────
AUDIT_LOG_PATH=/var/log/clawos/worker.log
